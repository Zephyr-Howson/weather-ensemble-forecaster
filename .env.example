# Optional: override default local SQLite database path
WEATHER_DB_PATH=data/weather.db

# Default location if not supplied in the CLI
DEFAULT_LAT=-37.8136
DEFAULT_LON=144.9631
DEFAULT_LOCATION_NAME=Melbourne
DEFAULT_TIMEZONE=Australia/Melbourne

# Use a shorter window initially if you only have 2 weeks of data
ROLLING_WINDOW_DAYS=14

# Optional forecast providers. Leave blank to skip these collectors.
# WEATHERAPI_KEY also enables an actuals override: --record-actual/--backfill
# use WeatherAPI's history endpoint to fill in observed uv_index, since
# Open-Meteo's Archive API never computes UV at all (see service.
# _fetch_blended_actual). Leave blank to skip both the forecast collector and
# the UV backfill.
WEATHERAPI_KEY=
VISUAL_CROSSING_KEY=

# One Call 3.0 requires the "One Call by Call" plan - free up to 1,000 calls/day,
# but OpenWeatherMap requires a credit card on file even for the free tier.
OPENWEATHERMAP_KEY=
WEATHERBIT_KEY=
ACCUWEATHER_KEY=

# SILO (Australia-only, BOM-derived, free) is not a forecast provider - it's an
# independent ground-truth source for actuals, blended in the same way as
# WeatherAPI's UV override above but for rainfall/max/min temp instead (see
# service._fetch_blended_actual); leave blank to skip it and keep pure
# Open-Meteo actuals for those fields. Only needs an email address, not a
# formal API key.
SILO_EMAIL=
